{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mcp_everything": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-everything"]
    },
    "jira": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true,
      "type": "remote"
    }
  }
}

